    <div class="card">
      <div class="card-title" style="margin-bottom:12px">📊 Scénarios selon votre usage</div>
      <div class="sc-wrap">
        <table id="sc-table"></table>
      </div>
      <div class="note">Hypothèse hausse tarif EDF <strong>+4%/an</strong> · Revente surplus 4 cts/kWh · Zone Grand Est 1 500 kWh/m²/an</div>
    </div>

    <div class="card">
      <div class="card-title" style="margin-bottom:12px">💶 Détail financier</div>
      <table class="detail-table" id="r-detail"></table>
    </div>

    <div class="cta">
      <div class="cta-title">🎯 Étude gratuite & visite offerte</div>
      <div class="cta-sub">Cette simulation est une estimation. Notre équipe RGE se déplace gratuitement pour une étude complète avec devis sans engagement.</div>

      <div class="field">
        <label>Votre nom</label>
        <input type="text" id="l-nom" placeholder="Jean Dupont">
      </div>
      <div class="row2">
        <div class="field">
          <label>Téléphone</label>
          <input type="tel" id="l-tel" placeholder="06 xx xx xx xx">
        </div>
        <div class="field">
          <label>Code postal</label>
          <input type="text" id="l-cp" placeholder="57xxx">
        </div>
      </div>
      <div class="field">
        <label>Email (optionnel)</label>
        <input type="email" id="l-email" placeholder="email@exemple.fr">
      </div>

      <button class="btn-cta" onclick="submit()">📞 Demander mon étude gratuite</button>

      <div class="contacts">
        <a class="contact-link" href="tel:+33699479944">📞 06 99 47 99 44</a>
        <a class="contact-link" href="/cdn-cgi/l/email-protection#44272b2a30252730042536302d37252a3721272b282b232d353121376a2236">✉️ <span class="__cf_email__" data-cfemail="52313d3c26333126123320263b21333c2137313d3e3d353b232737217c3420">[email&#160;protected]</span></a>
        <span style="font-size:.78rem;color:#6B82A0">📍 Thionville · Moselle · 57</span>
      </div>
    </div>

    <div class="nav" style="margin-top:8px">
      <button class="btn-back" onclick="go(4)">← Modifier</button>
      <button class="btn-next" onclick="go(1)">🔄 Nouvelle simulation</button>
    </div>

  </div>
</div>

<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// STATE
var D={
  chauf:'elec',occ:'34',
  meth:'annuel', // annuel / semestre / mensuel
  conso:5000,
  consoEte:1500, consoHiver:3500,
  consoMensuel:[900,800,650,450,350,280,260,290,400,550,750,850],
  tarif:0.2276,
  orient:'S',surf:'med',ombre:'non',
  ve:'non',clim:false,piscine:false,cumulus:false,seche:false,
  presence:'partiel'
};

var MOIS=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];

// Profil mensuel type (ratio) pour répartition automatique
var PROFIL_HIVER=[.13,.12,.10,.07,.05,.04,.04,.04,.06,.08,.12,.11]; // chauffage élec
var PROFIL_ETE  =[.06,.06,.07,.08,.10,.12,.13,.12,.10,.08,.05,.06]; // profil moyen

var cur=1;

// INIT grille mensuelle
function initMonthly(){
  var g=document.getElementById('monthly-inputs');
  if(!g)return;
  var html='';
  for(var i=0;i<12;i++){
    html+='<div style="text-align:center">'+
      '<div style="font-size:.65rem;color:#6B82A0;margin-bottom:4px;font-weight:600">'+MOIS[i]+'</div>'+
      '<input type="number" id="m'+i+'" value="'+D.consoMensuel[i]+'" min="0" max="3000" '+
      'style="width:100%;padding:8px 4px;border-radius:8px;border:1.5px solid #1F2D45;'+
      'background:rgba(255,255,255,.03);color:#F0F4FF;font-size:14px;text-align:center;outline:none" '+
      'oninput="updMonthly()">'+
      '</div>';
  }
  g.innerHTML=html;
}

function updMonthly(){
  var total=0;
  for(var i=0;i<12;i++){
    var el=document.getElementById('m'+i);
    var v=parseInt(el?el.value:0)||0;
    D.consoMensuel[i]=v;
    total+=v;
  }
  D.conso=total;
  var el2=document.getElementById('cv-total-men');
  if(el2) el2.textContent=new Intl.NumberFormat('fr-FR').format(total)+' kWh';
}

// MÉTHODE SAISIE
function setMeth(el,meth){
  var opts=el.parentElement.querySelectorAll('.opt');
  for(var i=0;i<opts.length;i++) opts[i].classList.remove('sel');
  el.classList.add('sel');
  D.meth=meth;
  document.getElementById('m-annuel').style.display=meth==='annuel'?'block':'none';
  document.getElementById('m-semestre').style.display=meth==='semestre'?'block':'none';
  document.getElementById('m-mensuel').style.display=meth==='mensuel'?'block':'none';
  if(meth==='mensuel') initMonthly();
}

// SLIDER ANNUEL
function uC(v){
  D.conso=parseInt(v);
  var el=document.getElementById('cv');
  if(el) el.textContent=new Intl.NumberFormat('fr-FR').format(v)+' kWh';
  // Répartir sur profil type
  for(var i=0;i<12;i++) D.consoMensuel[i]=Math.round(D.conso*PROFIL_HIVER[i]);
}
function sC(v){
  var sl=document.getElementById('csl');
  if(sl) sl.value=v;
  uC(v);
  var btns=document.querySelectorAll('.qbtn');
  for(var i=0;i<btns.length;i++) btns[i].classList.remove('sel');
}

// SLIDERS SEMESTRE
function uSem(saison,v){
  v=parseInt(v);
  if(saison==='ete'){
    D.consoEte=v;
    var el=document.getElementById('cv-ete');
    if(el) el.textContent=new Intl.NumberFormat('fr-FR').format(v)+' kWh';
    // Répartir sur avr-sep
    var moisEte=[3,4,5,6,7,8]; // indices avril→septembre
    for(var i=0;i<6;i++) D.consoMensuel[moisEte[i]]=Math.round(v/6);
  }else{
    D.consoHiver=v;
    var el2=document.getElementById('cv-hiver');
    if(el2) el2.textContent=new Intl.NumberFormat('fr-FR').format(v)+' kWh';
    // Répartir sur oct-mar (avec pondération chauffage)
    var moisHiver=[9,10,11,0,1,2]; // oct→mar
    var poidsHiver=[.13,.18,.20,.22,.17,.10];
    for(var j=0;j<6;j++) D.consoMensuel[moisHiver[j]]=Math.round(v*poidsHiver[j]);
  }
  D.conso=D.consoEte+D.consoHiver;
  var el3=document.getElementById('cv-total-sem');
  if(el3) el3.textContent=new Intl.NumberFormat('fr-FR').format(D.conso)+' kWh';
}

// NAVIGATION
function go(n){
  document.getElementById('p'+cur).classList.remove('active');
  document.getElementById('p'+n).classList.add('active');
  cur=n;
  updProg(n);
  window.scrollTo(0,0);
}

function updProg(n){
  var pcts=[0,20,40,60,80,100];
  document.getElementById('prog').style.width=pcts[n]+'%';
  var lbls=['Logement','Conso','Toiture','Équipements','Résultats'];
  for(var i=1;i<=5;i++){
    var el=document.getElementById('ps'+i);
    el.className='prog-step'+(i<n?' done':i===n?' active':'');
  }
}

// SÉLECTION UNIQUE
function ch(el,key,val){
  var siblings=el.parentElement.querySelectorAll('.opt');
  for(var i=0;i<siblings.length;i++) siblings[i].classList.remove('sel');
  el.classList.add('sel');
  D[key]=val;
}

// SÉLECTION MULTIPLE
function tog(el,key){
  el.classList.toggle('sel');
  D[key]=el.classList.contains('sel');
}

// SLIDER CONSO
function uC(v){
  D.conso=parseInt(v);
  document.getElementById('cv').textContent=new Intl.NumberFormat('fr-FR').format(v)+' kWh';
}
function sC(v){
  document.getElementById('csl').value=v;
  uC(v);
  var btns=document.querySelectorAll('.qbtn');
  for(var i=0;i<btns.length;i++) btns[i].classList.remove('sel');
}

// FORMATAGE
function f(n){return new Intl.NumberFormat('fr-FR').format(Math.round(n));}

// CALCUL ROI
function roi(gain,invest){
  var c=0;
  for(var an=1;an<=35;an++){
    c+=gain*Math.pow(1.04,an-1);
    if(c>=invest) return an;
  }
  return 0;
}

// CALCUL PRINCIPAL
function calcul(){
  try{
    var IRR=1500, PR=0.78;
    var tarif=parseFloat(D.tarif)||0.2276;
    var HAUSSE=0.04;

    // Puissance
    var kwcMap={small:3,med:6,large:9};
    var kwc=kwcMap[D.surf]||6;
    if(D.conso>12000&&D.surf==='large') kwc=9;
    if(D.conso<4000&&D.surf==='med') kwc=3;

    // Orientation
    var azF={S:1,SE:0.92,SO:0.95,E:0.80,O:0.80,NS:0.88};
    var az=azF[D.orient]||1;

    // Ombrage
    var omF={non:1,peu:0.92,fort:0.80};
    var om=omF[D.ombre]||1;

    // Production annuelle
    var prod=Math.round(kwc*IRR*PR*az*om);

    // Répartition mensuelle production (ratio solaire)
    var MR=[.04,.055,.085,.10,.115,.125,.13,.12,.10,.075,.045,.03];

    // Autoconsommation MENSUELLE avec données réelles
    // Facteurs de coïncidence selon profil
    var veB={non:0,peu:0.05,moy:0.10,freq:0.15};
    var veBonus=veB[D.ve]||0;

    var COINC=[0.85,0.82,0.72,0.60,0.48,0.40,0.38,0.40,0.52,0.65,0.80,0.84];
    // Bonus équipements
    if(D.clim){COINC[4]+=.06;COINC[5]+=.08;COINC[6]+=.10;COINC[7]+=.08;COINC[8]+=.06;}
    if(D.piscine){COINC[4]+=.05;COINC[5]+=.07;COINC[6]+=.08;COINC[7]+=.07;COINC[8]+=.05;}
    if(D.cumulus){for(var k=0;k<12;k++) COINC[k]+=.03;}
    if(D.presence==='souvent'){for(var k=0;k<12;k++) COINC[k]+=.06;}
    if(D.presence==='partiel'){for(var k=0;k<12;k++) COINC[k]+=.03;}
    // VE boost été
    if(veBonus>0){COINC[3]+=veBonus;COINC[4]+=veBonus;COINC[5]+=veBonus;COINC[6]+=veBonus;COINC[7]+=veBonus;COINC[8]+=veBonus;}

    var autoTotal=0, surpTotal=0;
    for(var i=0;i<12;i++){
      var prodM=prod*MR[i];
      var consoM=D.consoMensuel[i];
      var coinc=Math.min(0.92,COINC[i]);
      var prodUtile=prodM*coinc;
      var autoM=Math.min(prodUtile,consoM);
      autoTotal+=autoM;
      surpTotal+=Math.max(0,prodM-autoM);
    }

    var tauto=Math.round(autoTotal/Math.max(prod,1)*100);
    var eco=Math.round(autoTotal*tarif);
    var rev=Math.round(surpTotal*0.04);
    var gain=eco+rev;

    // Investissement
    var estim={small:7500,med:11900,large:15300};
    var invest=estim[D.surf]||11900;
    var prime=Math.round(kwc*80);
    var net=invest-prime;

    // KPIs
    document.getElementById('r-kwc').textContent=kwc.toFixed(1);
    document.getElementById('r-prod').textContent=f(prod);
    document.getElementById('r-gain').textContent=f(gain);

    // Scénarios ±10%
    var sc=[
      {lbl:'Prudent',em:'🔵',pct:Math.max(25,tauto-10)},
      {lbl:'Réaliste',em:'✅',pct:tauto,main:true},
      {lbl:'Optimiste',em:'🟢',pct:Math.min(75,tauto+10)},
    ];
    var tbl='<tr><th>Scénario</th><th>Autoconso</th><th>Gain/an</th><th>ROI +4%/an</th></tr>';
    for(var i=0;i<sc.length;i++){
      var s=sc[i];
      var a2=prod*(s.pct/100), su2=prod-a2;
      var g2=Math.round(a2*tarif)+Math.round(su2*0.04);
      var r2=roi(g2,net);
      tbl+='<tr'+(s.main?' class="main"':'')+'>'+
        '<td>'+s.em+' '+s.lbl+'</td>'+
        '<td>'+s.pct+'%</td>'+
        '<td class="gain">'+f(g2)+' €</td>'+
        '<td class="roi">'+(r2>0?r2+' ans':'> 35 ans')+'</td>'+
      '</tr>';
    }
    document.getElementById('sc-table').innerHTML=tbl;

    // Détail
    var det='<tr class="hd"><td colspan="2">Investissement</td></tr>'+
      '<tr><td>Installation clé en main TTC (TVA 5,5%)</td><td>'+f(invest)+' €</td></tr>'+
      '<tr><td>Prime EDF OA (80 €/kWc)</td><td style="color:#22C55E">− '+f(prime)+' €</td></tr>'+
      '<tr><td><strong>Net après prime</strong></td><td><strong>'+f(net)+' €</strong></td></tr>'+
      '<tr class="hd"><td colspan="2">Gains annuels — scénario réaliste ('+tauto+'% autoconso)</td></tr>'+
      '<tr><td>Économies sur facture EDF</td><td>'+f(eco)+' €/an</td></tr>'+
      '<tr><td>Revente surplus EDF OA</td><td>'+f(rev)+' €/an</td></tr>'+
      '<tr><td><strong>Gain total annuel</strong></td><td><strong style="color:#22C55E">'+f(gain)+' €/an</strong></td></tr>';
    document.getElementById('r-detail').innerHTML=det;

  }catch(e){
    document.getElementById('sc-table').innerHTML='<tr><td colspan="4">Erreur : '+e.message+'</td></tr>';
  }
}

// SOUMISSION
function submit(){
  var nom=document.getElementById('l-nom').value.trim();
  var tel=document.getElementById('l-tel').value.trim();
  if(!nom||!tel){alert('Merci de renseigner votre nom et téléphone.');return;}
  document.querySelector('.cta').innerHTML=
    '<div class="confirm">'+
    '<div class="confirm-icon">✅</div>'+
    '<div class="confirm-title">Merci '+nom+' !</div>'+
    '<div class="confirm-sub">Notre équipe vou
